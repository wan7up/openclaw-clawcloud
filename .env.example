# OpenClaw for ClawCloud Run - example environment variables
#
# Copy these into your ClawCloud Run service env settings.
# Do not commit real secrets.

# Required: gateway token used by the web UI / clients
OPENCLAW_GATEWAY_TOKEN=replace-me

# Required: MUST be the real public origin assigned by ClawCloud Run
# Example: https://your-app.us-west-1.clawcloudrun.com
OPENCLAW_ALLOWED_ORIGIN=https://your-app.us-west-1.clawcloudrun.com

# Recommended persistent paths
OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace

# Internal gateway / external HTTP ports
OPENCLAW_GATEWAY_PORT=18789
PORT=8080

# If using OpenAI or an OpenAI-compatible endpoint
OPENAI_API_KEY=replace-me

# Optional: only set this when using an OpenAI-compatible relay/proxy/base URL
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1

# Optional: if set, startup will use this as the primary model and
# shrink the visible provider model list to this single model.
# OPENAI_MODEL=gpt-5.1-codex-mini
